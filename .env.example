# StartupScout Configuration

# Groq LLM (optional — enrichment stage)
GROQ_API_KEY=

# YC API (Required for YC. Find these in the Network tab when searching on ycombinator.com/companies)
YC_ALGOLIA_API_KEY=
YC_ALGOLIA_APP_ID=45BWZJ1SGC

# Crawler settings
CRAWLER_CONCURRENCY=5
CRAWLER_DELAY_MIN=1.0
CRAWLER_DELAY_MAX=3.0
CRAWLER_TIMEOUT=30
CRAWLER_MAX_RETRIES=3

# Export settings
OUTPUT_DIR=./output
EXPORT_FORMAT=csv,json

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/startupscout.log
